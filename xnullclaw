" "$tmpdir"
}

# ── Global: running ─────────────────────────────────────────────
cmd_running() {
    local json_mode=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json) json_mode=true; shift ;;
            *) die "Unknown flag: $1" ;;
        esac
    done

    local running_agents=()
    for dir in "$XNULLCLAW_HOME"/*/; do
        [[ -d "$dir" ]] || continue
        local name; name=$(basename "$dir")
        [[ "$name" == ".tmp" || "$name" == ".mux" ]] && continue
        [[ -f "${dir}/config.json" ]] || continue
        is_running "$name" && running_agents+=("$name")
    done

    if [[ ${#running_agents[@]} -eq 0 ]]; then
        if $json_mode; then
            echo "[]"
        else
            echo "No running agents."
        fi
        return
    fi

    if $json_mode; then
        python3 -c "
import json, subprocess, sys, os
from datetime import datetime, timezone

home = os.environ.get('XNULLCLAW_HOME', os.path.expanduser('~/.xnullclaw'))
agents = sys.argv[1:]
results = []
for name in agents:
    cname = 'xnc-' + name
    entry = {'name': name, 'status': 'running'}

    # Port
    try:
        port_lines = subprocess.check_output(
            ['docker', 'port', cname], stderr=subprocess.DEVNULL, text=True
        ).strip()
        if port_lines:
            port = int(port_lines.split(':')[-1])
            entry['port'] = port
    except Exception:
        pass

    # Uptime
    try:
        started = subprocess.check_output(
            ['docker', 'inspect', '--format', '{{.State.StartedAt}}', cname],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
        entry['started'] = started
        start_dt = datetime.fromisoformat(started.replace('Z', '+00:00'))
        now = datetime.now(timezone.utc)
        delta = now - start_dt
        hours, rem = divmod(int(delta.total_seconds()), 3600)
        mins = rem // 60
        entry['uptime'] = f'{hours}h{mins:02d}m' if hours > 0 else f'{mins}m'
    except Exception:
        entry['uptime'] = '?'

    # Restart count
    try:
        restarts = subprocess.check_output(
            ['docker', 'inspect', '--format', '{{.RestartCount}}', cname],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
        entry['restarts'] = int(restarts)
    except Exception:
        entry['restarts'] = 0

    # Emoji from .meta
    try:
        meta_path = os.path.join(home, name, '.meta')
        with open(meta_path) as f:
            for line in f:
                if line.startswith('EMOJI='):
                    entry['emoji'] = line.strip().split('=', 1)[1]
                    break
    except Exception:
        pass

    results.append(entry)

print(json.dumps(results, indent=2))
" "${running_agents[@]}"
    else
        printf "\033[1m%-20s %-8s %-8s %-10s %s\033[0m\n" "AGENT" "PORT" "UPTIME" "RESTARTS" "EMOJI"
        for name in "${running_agents[@]}"; do
            local cname; cname=$(container_name "$name")
            local port uptime restarts emoji

            port=$(docker port "$cname" 2>/dev/null | head -1 | awk -F: '{print $NF}' || true)
            [[ -z "$port" ]] && port="-"

            local started_at
            started_at=$(docker inspect "$cname" --format '{{.State.StartedAt}}' 2>/dev/null || echo "")
            if [[ -n "$started_at" ]]; then
                local start_epoch now_epoch diff_s hours mins
                start_epoch=$(epoch_from_iso "$started_at")
                now_epoch=$(date +%s)
                diff_s=$((now_epoch - start_epoch))
                hours=$((diff_s / 3600))
                mins=$(( (diff_s % 3600) / 60 ))
                if [[ $hours -gt 0 ]]; then
                    uptime="${hours}h$(printf '%02d' "$mins")m"
                else
                    uptime="${mins}m"
                fi
            else
                uptime="?"
            fi

            restarts=$(docker inspect "$cname" --format '{{.RestartCount}}' 2>/dev/null || echo "0")
            emoji=$(read_meta "$name" "EMOJI" "")

            printf "%-20s %-8s %-8s %-10s %s\n" "$name" "$port" "$uptime" "$restarts" "$emoji"
        done
    fi
}

# ── Global: list --json ─────────────────────────────────────────
cmd_list_json() {
    if [[ ! -d "$XNULLCLAW_HOME" ]]; then
        echo "[]"
        return
    fi

    python3 -c "
import json, subprocess, sys, os

home = os.environ.get('XNULLCLAW_HOME', os.path.expanduser('~/.xnullclaw'))
results = []

for name in sorted(os.listdir(home)):
    agent_dir = os.path.join(home, name)
    if name.startswith('.') or not os.path.isdir(agent_dir):
        continue
    config_path = os.path.join(agent_dir, 'config.json')
    if not os.path.isfile(config_path):
        continue

    entry = {'name': name}

    # Status
    try:
        out = subprocess.check_output(
            ['docker', 'ps', '-q', '-f', 'name=^xnc-' + name + '\$'],
            stderr=subprocess.DEVNULL, text=True
        ).strip()
        entry['status'] = 'running' if out else 'stopped'
    except Exception:
        entry['status'] = 'stopped'

    # Read .meta
    meta_path = os.path.join(agent_dir, '.meta')
    meta = {}
    if os.path.isfile(meta_path):
        with open(meta_path) as f:
            for line in f:
                line = line.strip()
                if '=' in line:
                    k, v = line.split('=', 1)
                    meta[k] = v

    entry['created'] = meta.get('CREATED', '')
    if 'EMOJI' in meta:
        entry['emoji'] = meta['EMOJI']

    # Read model from config
    try:
        with open(config_path) as f:
            cfg = json.load(f)
        model = cfg.get('agents', {}).get('defaults', {}).get('model', {}).get('primary', '')
        entry['model'] = model
    except Exception:
        entry['model'] = ''

    results.append(entry)

print(json.dumps(results, indent=2))
"
}

