}

# ── Agent: config set ───────────────────────────────────────────
cmd_config_set() {
    local agent="$1" key="$2" value="$3"
    agent_exists "$agent" || die "Agent '${agent}' not found."

    local config_file; config_file="$(agent_dir "$agent")/config.json"

    python3 -c "
import json, sys

config_path = sys.argv[1]
key = sys.argv[2]
value = sys.argv[3]

key_map = {
    'model':                ('agents.defaults.model.primary',   'string'),
    'temperature':          ('default_temperature',             'float'),
    'autonomy':             ('autonomy.level',                  'string'),
    'system_prompt':        ('agents.defaults.system_prompt',   'string'),
    'max_actions_per_hour': ('autonomy.max_actions_per_hour',   'int'),
    'memory_backend':       ('memory.backend',                  'string'),
    'cost_enabled':         ('cost.enabled',                    'bool'),
    'cost_daily_limit':     ('cost.daily_limit_usd',            'float'),
    'cost_monthly_limit':   ('cost.monthly_limit_usd',          'float'),
}

if key not in key_map:
    supported = ', '.join(sorted(key_map.keys()))
    print(f'error: unknown key \"{key}\". Supported: {supported}', file=sys.stderr)
    sys.exit(1)

json_path, val_type = key_map[key]

# Cast value
if val_type == 'float':
    value = float(value)
elif val_type == 'int':
    value = int(value)
elif val_type == 'bool':
    value = value.lower() in ('true', '1', 'yes')

with open(config_path) as f:
    cfg = json.load(f)

# Navigate and set nested key
parts = json_path.split('.')
obj = cfg
for p in parts[:-1]:
    if p not in obj:
        obj[p] = {}
    obj = obj[p]
obj[parts[-1]] = value

with open(config_path, 'w') as f:
    json.dump(cfg, f, indent=2)
    f.write('\n')

print(f'{key} = {json.dumps(value)}')
" "$config_file" "$key" "$value"
}

# ── Agent: costs ────────────────────────────────────────────────
cmd_costs() {
    local agent="$1"; shift
    agent_exists "$agent" || die "Agent '${agent}' not found."

    local json_mode=false
    local period="all"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)  json_mode=true; shift ;;
            --today) period="today"; shift ;;
            --month) period="month"; shift ;;
            *) die "Unknown flag: $1" ;;
        esac
    done

    local costs_file; costs_file="$(agent_dir "$agent")/data/.nullclaw/state/costs.jsonl"

    if [[ ! -f "$costs_file" ]]; then
        if $json_mode; then
            echo '{"total_usd":0,"requests":0,"period":"'"$period"'"}'
        else
            echo "No cost data for agent '${agent}'."
        fi
        return
    fi

    python3 -c "
import json, sys
from datetime import datetime, date

costs_file = sys.argv[1]
period = sys.argv[2]
json_mode = sys.argv[3] == 'true'

today = date.today()
entries = []
with open(costs_file) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
            entries.append(entry)
        except json.JSONDecodeError:
            continue

# Filter by period
filtered = []
for e in entries:
    ts = e.get('timestamp', e.get('ts', ''))
    try:
        dt = datetime.fromisoformat(ts.replace('Z', '+00:00'))
        entry_date = dt.date()
    except Exception:
        entry_date = None

    if period == 'today' and entry_date != today:
        continue
    if period == 'month' and (entry_date is None or entry_date.year != today.year or entry_date.month != today.month):
        continue
    filtered.append(e)

total_usd = sum(e.get('cost_usd', e.get('cost', 0)) for e in filtered)
total_input = sum(e.get('input_tokens', 0) for e in filtered)
total_output = sum(e.get('output_tokens', 0) for e in filtered)
count = len(filtered)

if json_mode:
    result = {
        'total_usd': round(total_usd, 4),
        'requests': count,
        'input_tokens': total_input,
        'output_tokens': total_output,
        'period': period,
    }
    print(json.dumps(result, indent=2))
else:
    period_label = {'all': 'All time', 'today': 'Today', 'month': 'This month'}[period]
    print(f'Cost summary ({period_label}):')
    print(f'  Requests:      {count}')
    print(f'  Input tokens:  {total_input:,}')
    print(f'  Output tokens: {total_output:,}')
    print(f'  Total cost:    \${total_usd:.4f}')
" "$costs_file" "$period" "$json_mode"
}

# ── Agent: drain ────────────────────────────────────────────────
cmd_drain() {
    local agent="$1"
    _log DEBUG "drain: agent=$agent"
    agent_exists "$agent" || die "Agent '${agent}' not found."
    is_running "$agent"   || die "Agent '${agent}' is not running."

    local cname; cname=$(container_name "$agent")
    local last_drain; last_drain=$(read_meta "$agent" "LAST_DRAIN" "")

    local log_args=(docker logs)
    if [[ -n "$last_drain" && "$last_drain" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$ ]]; then
        log_args+=(--since "$last_drain")
    fi
    log_args+=("$cname")

    # Update drain timestamp before reading (use current time)
    write_meta "$agent" "LAST_DRAIN" "$(iso_now)"

    # Get logs and filter for structured output events
    "${log_args[@]}" 2>&1 | grep -E '^\[EVENT\]|^\{' || true
}

# ── Agent: watch ────────────────────────────────────────────────
cmd_watch() {
    local agent="$1"
    agent_exists "$agent" || die "Agent '${agent}' not found."
    is_running "$agent"   || die "Agent '${agent}' is not running."

    local cname; cname=$(container_name "$agent")
    local since; since=$(iso_now)

    exec docker logs --follow --since "$since" "$cname" 2>&1
}

# ── Mux management ──────────────────────────────────────────────
cmd_mux() {
    local subcmd="${1:-}"
    [[ -n "$subcmd" ]] || die "Usage: xnullclaw mux <start|stop|status|logs>"
    shift

    local mux_dir="$XNULLCLAW_HOME/.mux"
    local mux_pid_file="$mux_dir/mux.pid"
    local mux_log_dir="$mux_dir/logs"
    local mux_log_file="$mux_log_dir/mux.log"

    case "$subcmd" in
        start)
            _log DEBUG "mux start"
            mkdir -p "$mux_dir" "$mux_log_dir"

            # Check if already running
            if [[ -f "$mux_pid_file" ]]; then
                local pid; pid=$(cat "$mux_pid_file")
                if kill -0 "$pid" 2>/dev/null; then
                    die "Mux is already running (PID ${pid})."
                fi
                # Stale PID file
                rm -f "$mux_pid_file"
            fi

            local mux_bin="${XNULLCLAW_MUX_BIN:-xnc-mux}"
            command -v "$mux_bin" &>/dev/null || die "Mux binary '${mux_bin}' not found in PATH."

            info "Starting mux..."
            nohup "$mux_bin" >> "$mux_log_file" 2>&1 &
            local pid=$!
            echo "$pid" > "$mux_pid_file"
            ok "Mux started (PID ${pid}). Log: ${mux_log_file}"
            ;;

        stop)
            _log DEBUG "mux stop"
            if [[ ! -f "$mux_pid_file" ]]; then
                die "Mux is not running (no PID file)."
            fi
            local pid; pid=$(cat "$mux_pid_file")
            [[ "$pid" =~ ^[0-9]+$ ]] || { rm -f "$mux_pid_file"; die "Corrupt PID file."; }
            if kill -0 "$pid" 2>/dev/null; then
                info "Stopping mux (PID ${pid})..."
                kill -TERM "$pid"
                # Wait up to 5 seconds for graceful shutdown
                local i=0
                while kill -0 "$pid" 2>/dev/null && [[ $i -lt 10 ]]; do
                    sleep 0.5
                    i=$((i + 1))
                done
                if kill -0 "$pid" 2>/dev/null; then
                    warn "Mux did not stop gracefully, sending SIGKILL..."
                    kill -KILL "$pid" 2>/dev/null || true
                fi
                rm -f "$mux_pid_file"
                ok "Mux stopped."
            else
                rm -f "$mux_pid_file"
                warn "Mux was not running (stale PID). Cleaned up."
            fi
            ;;

        status)
            if [[ -f "$mux_pid_file" ]]; then
                local pid; pid=$(cat "$mux_pid_file")
                [[ "$pid" =~ ^[0-9]+$ ]] || { rm -f "$mux_pid_file"; die "Corrupt PID file."; }
                if kill -0 "$pid" 2>/dev/null; then
                    echo "Mux:    running (PID ${pid})"
                    echo "Log:    ${mux_log_file}"
                    # Show uptime from PID file modification time
                    local started
                    started=$(portable_stat_mtime "$mux_pid_file")
                    if [[ -n "$started" ]]; then
                        local now diff_s hours mins
                        now=$(date +%s)
                        diff_s=$((now - started))
                        hours=$((diff_s / 3600))
                        mins=$(( (diff_s % 3600) / 60 ))
                        if [[ $hours -gt 0 ]]; then
                            echo "Uptime: ${hours}h$(printf '%02d' "$mins")m"
                        else
                            echo "Uptime: ${mins}m"
                        fi
                    fi
                else
                    echo "Mux:    not running (stale PID file)"
                    rm -f "$mux_pid_file"
                fi
            else
                echo "Mux:    not running"
            fi
            ;;

        logs)
            if [[ -f "$mux_log_file" ]]; then
                tail "$@" "$mux_log_file"
            else
                echo "No mux log file found at ${mux_log_file}."
            fi
            ;;

        *) die "Unknown mux command: ${subcmd}. Try: start, stop, status, logs" ;;
    esac
}

