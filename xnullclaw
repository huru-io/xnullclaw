# ── Docker run helpers ───────────────────────────────────────────
# Common hardening args for all docker run invocations
docker_hardened_args() {
    local dir="$1"
    echo \
        --read-only \
        --tmpfs /tmp:size=64M,noexec,nosuid \
        --security-opt no-new-privileges:true \
        --cap-drop ALL \
        --user "$(id -u):$(id -g)" \
        -v "${dir}/data:/nullclaw-data" \
        -v "${dir}/config.json:/nullclaw-data/.nullclaw/config.json:ro"
}

# ── Agent: setup ─────────────────────────────────────────────────
cmd_setup() {
    local agent="$1"
    validate_name "$agent"
    local dir; dir="$(agent_dir "$agent")"

    if agent_exists "$agent"; then
        die "Agent '${agent}' already exists at ${dir}. Use 'clone' to duplicate."
    fi

    mkdir -p "${dir}/data/.nullclaw" "${dir}/data/workspace"
    generate_config > "${dir}/config.json"
    write_meta "$agent" "CREATED" "$(date -Iseconds)"

    ok "Agent '${agent}' created."
    cat <<EOF

  Directory: ${dir}/

  ┌─ EDIT BEFORE STARTING ─────────────────────────────────────┐
  │                                                             │
  │  \$ ${EDITOR:-vi} ${dir}/config.json
  │                                                             │
  │  REQUIRED:                                                  │
  │    Set your OpenAI API key:                                 │
  │      models.providers.openai.api_key                        │
  │                                                             │
  │  REQUIRED — Telegram:                                       │
  │    1. Create a bot via @BotFather on Telegram               │
  │    2. Set channels.telegram.accounts.main.bot_token         │
  │    3. Set allow_from to your Telegram user ID               │
  │       (use @userinfobot on Telegram to get your ID)         │
  │                                                             │
  │    Each agent needs its OWN Telegram bot.                   │
  │    Create a separate bot via @BotFather for each agent.     │
  │                                                             │
  │  OPTIONAL — Switch provider:                                │
  │    agents.defaults.model.primary can be:                    │
  │      "openai/gpt-4o"                                        │
  │      "openai/gpt-4o-mini"                                   │
  │      "openrouter/anthropic/claude-sonnet-4"                 │
  │      "anthropic/claude-sonnet-4"                            │
  │                                                             │
  └─────────────────────────────────────────────────────────────┘

  Then:
    xnullclaw ${agent} start      # always-on daemon (Telegram)
    xnullclaw ${agent} cli        # interactive local chat

EOF
}

# ── Agent: start ─────────────────────────────────────────────────
cmd_start() {
    local agent="$1"
    shift
    agent_exists "$agent" || die "Agent '${agent}' not found. Run: xnullclaw ${agent} setup"
    is_running "$agent"   && die "Agent '${agent}' is already running. Use 'restart' to restart."
    ensure_image

    local dir;   dir="$(agent_dir "$agent")"
    local cname; cname=$(container_name "$agent")

    # Parse optional --port flag
    local expose_port=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)
                if [[ $# -ge 2 && "$2" =~ ^[0-9]+$ ]]; then
                    expose_port="$2"; shift 2
                else
                    expose_port=$(next_port); shift
                fi
                ;;
            *) die "Unknown flag: $1" ;;
        esac
    done

    # Clean up any stopped container with the same name
    docker rm "$cname" 2>/dev/null || true

    # Build docker run command
    local -a run_args=(
        docker run -d
        --name "$cname"
        --restart unless-stopped
        --read-only
        --tmpfs /tmp:size=64M,noexec,nosuid
        --security-opt no-new-privileges:true
        --cap-drop ALL
        --user "$(id -u):$(id -g)"
        -v "${dir}/data:/nullclaw-data"
        -v "${dir}/config.json:/nullclaw-data/.nullclaw/config.json:ro"
    )

    if [[ -n "$expose_port" ]]; then
        run_args+=(
            -p "127.0.0.1:${expose_port}:3000"
            -e "NULLCLAW_GATEWAY_HOST=0.0.0.0"
            -e "NULLCLAW_ALLOW_PUBLIC_BIND=true"
        )
        write_meta "$agent" "HOST_PORT" "$expose_port"
        info "Starting agent '${agent}' (port ${expose_port})..."
    else
        info "Starting agent '${agent}' (no port exposed)..."
    fi

    run_args+=("$DOCKER_IMAGE" gateway)

    "${run_args[@]}" >/dev/null

    sleep 1

    ok "Agent '${agent}' started."
    echo ""
    if [[ -n "$expose_port" ]]; then
        echo "  Gateway: http://127.0.0.1:${expose_port}"
        local code
        code=$(docker logs "$cname" 2>&1 | grep -oP 'pairing code: \K\d+' || true)
        [[ -n "$code" ]] && echo "  Pairing: curl -s -X POST http://127.0.0.1:${expose_port}/pair -H 'X-Pairing-Code: ${code}'"
    else
        echo "  No port exposed (Telegram uses outbound polling)."
    fi
    echo "  Logs:    xnullclaw ${agent} logs -f"
    echo "  Stop:    xnullclaw ${agent} stop"
    echo ""
}

# ── Agent: stop ──────────────────────────────────────────────────
cmd_stop() {
    local agent="$1"
    if is_running "$agent"; then
        local cname; cname=$(container_name "$agent")
        info "Stopping agent '${agent}'..."
        docker stop "$cname" >/dev/null
        docker rm "$cname" >/dev/null 2>&1 || true
        ok "Agent '${agent}' stopped."
    else
        warn "Agent '${agent}' is not running."
    fi
}

# ── Agent: restart ───────────────────────────────────────────────
cmd_restart() {
    local agent="$1"
    shift
    cmd_stop "$agent" 2>/dev/null || true
    cmd_start "$agent" "$@"
}

# ── Agent: status ────────────────────────────────────────────────
cmd_status() {
    local agent="$1"
    agent_exists "$agent" || die "Agent '${agent}' not found."

    local dir; dir="$(agent_dir "$agent")"

    echo "Agent:     ${agent}"
    echo "Directory: ${dir}"

    if is_running "$agent"; then
        local cname; cname=$(container_name "$agent")
        local started ports
        started=$(docker inspect "$cname" --format '{{.State.StartedAt}}' 2>/dev/null || echo "?")
        ports=$(docker port "$cname" 2>/dev/null || true)

        echo "Status:    running"
        echo "Started:   ${started}"
        echo "Container: ${cname}"
        if [[ -n "$ports" ]]; then
            echo "Port:      ${ports}"
        else
            echo "Port:      none (outbound-only)"
        fi
    else
        echo "Status:    stopped"
    fi
}

# ── Agent: logs ──────────────────────────────────────────────────
cmd_logs() {
    local agent="$1"; shift
    is_running "$agent" || die "Agent '${agent}' is not running."
    local cname; cname=$(container_name "$agent")
    docker logs "$@" "$cname" 2>&1
}

# ── Agent: cli ───────────────────────────────────────────────────
cmd_cli() {
    local agent="$1"; shift
    agent_exists "$agent" || die "Agent '${agent}' not found. Run: xnullclaw ${agent} setup"
    ensure_image

    local dir; dir="$(agent_dir "$agent")"

    docker run --rm -it \
        --read-only \
        --tmpfs /tmp:size=64M,noexec,nosuid \
        --security-opt no-new-privileges:true \
        --cap-drop ALL \
        --user "$(id -u):$(id -g)" \
        -v "${dir}/data:/nullclaw-data" \
        -v "${dir}/config.json:/nullclaw-data/.nullclaw/config.json:ro" \
        "$DOCKER_IMAGE" \
        agent "$@"
}

# ── Agent: clone ─────────────────────────────────────────────────
cmd_clone() {
    local agent="$1" source="$2"
    local with_data="${3:-}"
    validate_name "$agent"
    agent_exists "$source" || die "Source agent '${source}' not found."
    agent_exists "$agent"  && die "Agent '${agent}' already exists."

    local src_dir; src_dir="$(agent_dir "$source")"
    local dst_dir; dst_dir="$(agent_dir "$agent")"

    info "Cloning '${source}' -> '${agent}'..."

    mkdir -p "${dst_dir}/data/.nullclaw" "${dst_dir}/data/workspace"
    cp "${src_dir}/config.json" "${dst_dir}/config.json"

    write_meta "$agent" "CREATED" "$(date -Iseconds)"
    write_meta "$agent" "CLONED_FROM" "$source"

    if [[ "$with_data" == "--with-data" ]]; then
        info "Copying data (memory, workspace, secrets)..."
        cp -a "${src_dir}/data/." "${dst_dir}/data/"
        info "Data copied."
    fi

    ok "Agent '${agent}' cloned from '${source}'."
    cat <<EOF

  Directory: ${dst_dir}/

  IMPORTANT — Review the config before starting:
    \$ ${EDITOR:-vi} ${dst_dir}/config.json

    - You MUST set a DIFFERENT Telegram bot_token.
      Each agent needs its own bot (@BotFather).
    - API keys are shared from the source config.
      Change them if you want separate billing/accounts.

  Start: xnullclaw ${agent} start

EOF
}

# ── Agent: destroy ───────────────────────────────────────────────
cmd_destroy() {
    local agent="$1"
    local dir; dir="$(agent_dir "$agent")"

    [[ -d "$dir" ]] || die "Agent '${agent}' not found."

    echo "This will PERMANENTLY DELETE agent '${agent}' and ALL its data."
    echo "Directory: ${dir}"
    echo ""
    read -rp "Type the agent name to confirm: " confirm
    [[ "$confirm" == "$agent" ]] || die "Aborted."

    is_running "$agent" && cmd_stop "$agent"

    rm -rf "$dir"
    ok "Agent '${agent}' destroyed."
}

# ── Global: list ─────────────────────────────────────────────────
cmd_list() {
    if [[ ! -d "$XNULLCLAW_HOME" ]]; then
        echo "No agents yet. Create one: xnullclaw <name> setup"
        return
    fi

    local found=false
    printf "\033[1m%-20s %-10s %-12s %s\033[0m\n" "AGENT" "STATUS" "CREATED" "CLONED_FROM"

    for dir in "$XNULLCLAW_HOME"/*/; do
        [[ -d "$dir" ]] || continue
        local name; name=$(basename "$dir")
        [[ "$name" == ".tmp" ]] && continue
        [[ -f "${dir}/config.json" ]] || continue

        found=true
        local created cloned status

        created=$(read_meta "$name" "CREATED" "-")
        cloned=$(read_meta "$name" "CLONED_FROM" "")

        if is_running "$name"; then
            status="\033[32mrunning\033[0m"
        else
            status="stopped"
        fi

        printf "%-20s %-10b %-12s %s\n" \
            "$name" "$status" "${created%%T*}" "$cloned"
    done

    $found || echo "No agents yet. Create one: xnullclaw <name> setup"
}

# ── Help ─────────────────────────────────────────────────────────
show_help() {
    cat <<'EOF'
xnullclaw - Multi-agent nullclaw wrapper with hardened Docker isolation

USAGE
  xnullclaw <agent> <command> [args...]
  xnullclaw <global-command>

AGENT COMMANDS
  setup                    Create agent with default config
  start                    Start always-on daemon (Telegram, no port exposed)
  start --port [PORT]      Start with HTTP gateway exposed on localhost
  stop                     Stop agent
  restart                  Restart agent
  status                   Show agent info
  logs [-f] [--tail N]     View/follow container logs
  cli [args...]            Interactive local chat (or -m "msg" for one-shot)
  clone <source>           Clone config from another agent (fresh data)
  clone <source> --with-data   Clone config AND memory/data
  destroy                  Permanently delete agent + all data

GLOBAL COMMANDS
  list                     List all agents and their status
  image build              Build Docker image from GitHub
  image update             Pull latest source + rebuild (no cache)
  image status             Show image info
  help                     Show this help

EXAMPLES
  xnullclaw alice setup                  Create agent 'alice'
  xnullclaw alice start                  Always-on Telegram agent
  xnullclaw alice start --port 3001      Also expose HTTP gateway
  xnullclaw alice cli                    Interactive chat session
  xnullclaw alice cli -m "Hello"         One-shot message
  xnullclaw alice logs -f                Follow live logs
  xnullclaw bob clone alice              New agent from alice's config
  xnullclaw bob clone alice --with-data  Clone with memory/history
  xnullclaw list                         Show all agents

FILE LAYOUT
  ~/.xnullclaw/
  ├── .tmp/nullclaw/                Git clone for building image
  └── <agent>/
      ├── .meta                     Metadata (managed by xnullclaw)
      ├── config.json               Nullclaw config (edit this)
      └── data/                     All agent data (persistent)
          ├── .nullclaw/            Secrets, auth, cron (auto-managed)
          └── workspace/            Memory, files (auto-managed)

DOCKER HARDENING (applied automatically)
  - Read-only root filesystem
  - All Linux capabilities dropped
  - no-new-privileges flag
  - No ports exposed by default
  - /tmp as noexec tmpfs
  - Runs as host user (no root in container)
  - Config mounted read-only

TELEGRAM
  Each agent MUST have its own Telegram bot token.
  Telegram uses outbound long-polling — no inbound ports needed.
  Create a separate bot via @BotFather for each agent.

ENVIRONMENT
  XNULLCLAW_HOME    Base directory   (default: ~/.xnullclaw)
  XNULLCLAW_IMAGE   Docker image     (default: nullclaw:latest)
EOF
}

# ── Main router ──────────────────────────────────────────────────
main() {
    [[ $# -ge 1 ]] || { show_help; exit 0; }

    case "$1" in
        help|--help|-h)
            show_help
            ;;
        list|ls)
            cmd_list
            ;;
        image)
            [[ $# -ge 2 ]] || die "Usage: xnullclaw image <build|update|status>"
            case "$2" in
                build)  cmd_image_build ;;
                update) cmd_image_update ;;
                status) cmd_image_status ;;
                *)      die "Unknown: image $2. Try: build, update, status" ;;
            esac
            ;;
        *)
            local agent="$1"
            [[ $# -ge 2 ]] || die "Usage: xnullclaw <agent> <command>. Run 'xnullclaw help' for details."
            local cmd="$2"
            shift 2

            case "$cmd" in
                setup)    cmd_setup "$agent" ;;
                start)    cmd_start "$agent" "$@" ;;
                stop)     cmd_stop "$agent" ;;
                restart)  cmd_restart "$agent" "$@" ;;
                status)   cmd_status "$agent" ;;
                logs)     cmd_logs "$agent" "$@" ;;
                cli)      cmd_cli "$agent" "$@" ;;
                clone)
                    [[ $# -ge 1 ]] || die "Usage: xnullclaw <agent> clone <source> [--with-data]"
                    cmd_clone "$agent" "$@"
                    ;;
                destroy)  cmd_destroy "$agent" ;;
                *)        die "Unknown command: ${cmd}. Run 'xnullclaw help' for details." ;;
            esac
            ;;
    esac
}

main "$@"
