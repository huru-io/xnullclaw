}

# ── Main router ──────────────────────────────────────────────────
main() {
    # Log command and subcommand only — avoid logging argument values (may contain secrets)
    _log DEBUG "invoked: ${1:-} ${2:-}"
    [[ $# -ge 1 ]] || { show_help; exit 0; }

    case "$1" in
        help|--help|-h)
            show_help
            ;;
        list|ls)
            shift
            if [[ "${1:-}" == "--json" ]]; then
                cmd_list_json
            else
                cmd_list
            fi
            ;;
        running)
            shift
            cmd_running "$@"
            ;;
        send-all)
            shift
            cmd_send_all
            ;;
        send-some)
            shift
            [[ $# -ge 1 ]] || die "Usage: echo 'msg' | xnullclaw send-some alice,bob"
            cmd_send_some "$1"
            ;;
        mux)
            shift
            cmd_mux "$@"
            ;;
        image)
            [[ $# -ge 2 ]] || die "Usage: xnullclaw image <build|update|status>"
            case "$2" in
                build)  cmd_image_build ;;
                update) cmd_image_update ;;
                status) cmd_image_status ;;
                *)      die "Unknown: image $2. Try: build, update, status" ;;
            esac
            ;;
        *)
            local agent="$1"
            [[ $# -ge 2 ]] || die "Usage: xnullclaw <agent> <command>. Run 'xnullclaw help' for details."
            validate_name "$agent"
            local cmd="$2"
            shift 2

            case "$cmd" in
                setup)    cmd_setup "$agent" ;;
                start)    cmd_start "$agent" "$@" ;;
                stop)     cmd_stop "$agent" ;;
                restart)  cmd_restart "$agent" "$@" ;;
                status)
                    if [[ "${1:-}" == "--json" ]]; then
                        cmd_status_json "$agent"
                    else
                        cmd_status "$agent"
                    fi
                    ;;
                logs)     cmd_logs "$agent" "$@" ;;
                cli)      cmd_cli "$agent" "$@" ;;
                clone)
                    [[ $# -ge 1 ]] || die "Usage: xnullclaw <agent> clone <source> [--with-data]"
                    cmd_clone "$agent" "$@"
                    ;;
                destroy)  cmd_destroy "$agent" ;;
                send)     cmd_send "$agent" ;;
                config)
                    local config_cmd="${1:-}"
                    shift || true
                    case "$config_cmd" in
                        get)  cmd_config_get "$agent" "${1:-}" ;;
                        set)
                            [[ $# -ge 2 ]] || die "Usage: xnullclaw ${agent} config set <key> <value>"
                            cmd_config_set "$agent" "$1" "$2"
                            ;;
                        *)    die "Usage: xnullclaw ${agent} config <get|set> [args...]" ;;
                    esac
                    ;;
                costs)    cmd_costs "$agent" "$@" ;;
                drain)    cmd_drain "$agent" ;;
                watch)    cmd_watch "$agent" ;;
                *)        die "Unknown command: ${cmd}. Run 'xnullclaw help' for details." ;;
            esac
            ;;
    esac
}

main "$@"
