# ── Agent: config get ───────────────────────────────────────────
cmd_config_get() {
    local agent="$1"
    local key="${2:-}"
    agent_exists "$agent" || die "Agent '${agent}' not found."

    local config_file; config_file="$(agent_dir "$agent")/config.json"

    if [[ -z "$key" ]]; then
        cat "$config_file"
        return
    fi

    python3 -c "
import json, sys

key = sys.argv[2]
with open(sys.argv[1]) as f:
    cfg = json.load(f)

key_map = {
    'model':                'agents.defaults.model.primary',
    'temperature':          'default_temperature',
    'autonomy':             'autonomy.level',
    'system_prompt':        'agents.defaults.system_prompt',
    'max_actions_per_hour': 'autonomy.max_actions_per_hour',
    'memory_backend':       'memory.backend',
    'cost_enabled':         'cost.enabled',
    'cost_daily_limit':     'cost.daily_limit_usd',
    'cost_monthly_limit':   'cost.monthly_limit_usd',
}

if key not in key_map:
    supported = ', '.join(sorted(key_map.keys()))
    print(f'error: unknown key \"{key}\". Supported: {supported}', file=sys.stderr)
    sys.exit(1)

path = key_map[key]
parts = path.split('.')
obj = cfg
for p in parts:
    if isinstance(obj, dict) and p in obj:
        obj = obj[p]
    else:
        print('(not set)', file=sys.stderr)
        sys.exit(0)

