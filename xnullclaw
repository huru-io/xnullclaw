#!/usr/bin/env bash
# xnullclaw - Multi-agent nullclaw wrapper with hardened Docker isolation
#
# Each agent lives in ~/.xnullclaw/<name>/ with its own config and data.
# Agents run in Docker with: read-only rootfs, all caps dropped,
# no-new-privileges, no exposed ports (Telegram uses outbound polling).
#
# Usage:  xnullclaw <agent> <command> [args...]
#         xnullclaw <global-command>

set -euo pipefail

# ── Configuration ────────────────────────────────────────────────
XNULLCLAW_HOME="${XNULLCLAW_HOME:-$HOME/.xnullclaw}"
DOCKER_IMAGE="${XNULLCLAW_IMAGE:-nullclaw:latest}"
CONTAINER_PREFIX="xnc"
REPO_URL="https://github.com/nullclaw/nullclaw.git"
BUILD_DIR="$XNULLCLAW_HOME/.tmp/nullclaw"
IS_MACOS=false; [[ "$(uname)" == "Darwin" ]] && IS_MACOS=true
XNULLCLAW_LOG="${XNULLCLAW_HOME}/.xnullclaw.log"

# ── Emoji identity pool ─────────────────────────────────────────
EMOJI_POOL=(
    "🍎" "🍊" "🍋" "🍇" "🍓" "🫐" "🍑" "🥝" "🍒" "🥭"
    "🌻" "🌸" "🌵" "🍀" "🌺" "🪻" "🌷" "🪷" "🌿" "🍄"
    "🐙" "🦊" "🐝" "🦉" "🐋" "🦎" "🐺" "🦜" "🐬" "🦋"
    "💎" "🔮" "⭐" "🌙" "❄️" "🔥" "🌈" "⚡" "🪐" "🌊"
)

# ── Helpers ──────────────────────────────────────────────────────
_log() {
    # Append timestamped entry to debug log. Silent if dir doesn't exist yet.
    local level="$1"; shift
    mkdir -p "$(dirname "$XNULLCLAW_LOG")" 2>/dev/null || true
    printf '%s [%s] %s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" "$level" "$*" >> "$XNULLCLAW_LOG" 2>/dev/null || true
    chmod 600 "$XNULLCLAW_LOG" 2>/dev/null || true
}
die()  { _log ERROR "$*"; printf '\033[31merror:\033[0m %s\n' "$*" >&2; exit 1; }
info() { _log INFO  "$*"; printf '\033[34m::\033[0m %s\n' "$*"; }
warn() { _log WARN  "$*"; printf '\033[33m!!\033[0m %s\n' "$*" >&2; }
ok()   { _log OK    "$*"; printf '\033[32mok:\033[0m %s\n' "$*"; }

container_name() { echo "${CONTAINER_PREFIX}-${1}"; }
agent_dir()      { echo "${XNULLCLAW_HOME}/${1}"; }

# Portable helpers (BSD/GNU compat)
iso_now() { date -u '+%Y-%m-%dT%H:%M:%SZ'; }
epoch_from_iso() {
    # Convert ISO8601 timestamp to epoch seconds.
    # Handles Docker format (2024-01-15T10:30:00.123456789Z) by stripping fractional seconds.
    local ts="${1%%.*}"          # strip .nanoseconds
    ts="${ts%Z}"                 # strip trailing Z if no fractional part
    ts="${ts}Z"                  # re-add Z for consistent format
    if $IS_MACOS; then
        date -j -f '%Y-%m-%dT%H:%M:%SZ' "$ts" +%s 2>/dev/null \
        || date -j -f '%Y-%m-%dT%H:%M:%S%z' "${ts%Z}+0000" +%s 2>/dev/null \
        || echo 0
    else
        date -d "$ts" +%s 2>/dev/null || echo 0
    fi
}
portable_sed_i() {
    # sed -i that works on both macOS (BSD) and Linux (GNU)
    if $IS_MACOS; then
        sed -i '' "$@"
    else
        sed -i "$@"
    fi
}
portable_stat_mtime() {
    # Return file modification time as epoch seconds
    if $IS_MACOS; then
        stat -f '%m' "$1" 2>/dev/null || echo ""
    else
        stat -c '%Y' "$1" 2>/dev/null || echo ""
    fi
}

validate_name() {
    [[ "$1" =~ ^[a-zA-Z][a-zA-Z0-9_-]*$ ]] || \
        die "Invalid agent name '$1'. Use letters, digits, hyphens, underscores. Must start with a letter."
}

agent_exists() { [[ -d "$(agent_dir "$1")" && -f "$(agent_dir "$1")/config.json" ]]; }

is_running() { docker ps -q -f "name=^$(container_name "$1")\$" 2>/dev/null | grep -q .; }

image_exists() { docker image inspect "$DOCKER_IMAGE" &>/dev/null; }

# ── Meta file (key=value store per agent) ────────────────────────
read_meta() {
    local meta; meta="$(agent_dir "$1")/.meta"
    if [[ -f "$meta" ]]; then
        grep "^${2}=" "$meta" 2>/dev/null | head -1 | cut -d= -f2- || echo "${3:-}"
    else
        echo "${3:-}"
    fi
}

write_meta() {
    local meta; meta="$(agent_dir "$1")/.meta"
    if [[ -f "$meta" ]] && grep -q "^${2}=" "$meta" 2>/dev/null; then
        portable_sed_i "s|^${2}=.*|${2}=${3}|" "$meta"
    else
        echo "${2}=${3}" >> "$meta"
    fi
}

next_port() {
    local port=3001
    while true; do
        local used=false
        local metas
        metas=$(compgen -G "$XNULLCLAW_HOME"/*/.meta 2>/dev/null || true)
        for meta in $metas; do
            [[ -f "$meta" ]] && grep -q "^HOST_PORT=${port}$" "$meta" && { used=true; break; }
        done
        $used || { echo "$port"; return; }
        ((port++))
    done
}

next_emoji() {
    # Collect all emojis currently assigned to existing agents
    local used_emojis=""
    local metas
    metas=$(compgen -G "$XNULLCLAW_HOME"/*/.meta 2>/dev/null || true)
    for meta in $metas; do
        local e
        e=$(grep "^EMOJI=" "$meta" 2>/dev/null | head -1 | cut -d= -f2- || true)
        [[ -n "$e" ]] && used_emojis="${used_emojis}${e}|"
    done

    # Find first unused emoji from the pool
    for emoji in "${EMOJI_POOL[@]}"; do
        case "$used_emojis" in
            *"${emoji}|"*) ;; # already used
            *) echo "$emoji"; return ;;
        esac
    done

    # All 40 emojis taken — fallback
    echo "🤖"
}

ensure_image() {
    if ! image_exists; then
        _log WARN "docker image missing: $DOCKER_IMAGE"
        warn "Docker image '${DOCKER_IMAGE}' not found."
        read -rp "Build it now from GitHub? [Y/n] " ans
        [[ "${ans:-y}" =~ ^[Yy] ]] || die "Cannot proceed without the Docker image."
        cmd_image_build
    fi
}

# ── Image commands ───────────────────────────────────────────────
cmd_image_build() {
    _log DEBUG "image build: image=$DOCKER_IMAGE build_dir=$BUILD_DIR"
    mkdir -p "$XNULLCLAW_HOME/.tmp"
    if [[ -d "$BUILD_DIR/.git" ]]; then
        info "Using existing repo at ${BUILD_DIR}"
    else
        info "Cloning nullclaw..."
        if ! git clone "$REPO_URL" "$BUILD_DIR"; then
            _log ERROR "git clone failed: repo=$REPO_URL"
            die "Failed to clone nullclaw repository."
        fi
    fi
    info "Building Docker image (compiling Zig — may take a few minutes)..."
    if ! docker build -t "$DOCKER_IMAGE" "$BUILD_DIR"; then
        _log ERROR "docker build failed: image=$DOCKER_IMAGE"
        die "Docker image build failed."
    fi
    ok "Image '${DOCKER_IMAGE}' built."
}

cmd_image_update() {
    _log DEBUG "image update: image=$DOCKER_IMAGE"
    mkdir -p "$XNULLCLAW_HOME/.tmp"
    if [[ -d "$BUILD_DIR/.git" ]]; then
        info "Pulling latest changes..."
        if ! git -C "$BUILD_DIR" pull --ff-only; then
            _log ERROR "git pull failed: dir=$BUILD_DIR"
            die "Failed to pull latest nullclaw changes."
        fi
    else
        info "Cloning nullclaw..."
        if ! git clone "$REPO_URL" "$BUILD_DIR"; then
            _log ERROR "git clone failed: repo=$REPO_URL"
            die "Failed to clone nullclaw repository."
        fi
    fi
    info "Rebuilding Docker image (no cache)..."
    if ! docker build --no-cache -t "$DOCKER_IMAGE" "$BUILD_DIR"; then
        _log ERROR "docker build (no-cache) failed: image=$DOCKER_IMAGE"
        die "Docker image rebuild failed."
    fi
    ok "Image '${DOCKER_IMAGE}' updated."
}

cmd_image_status() {
    if image_exists; then
        docker image inspect "$DOCKER_IMAGE" --format \
            "Image:   {{index .RepoTags 0}}
Created: {{.Created}}
Size:    {{.Size}}
ID:      {{.ID}}"
    else
        echo "Image '${DOCKER_IMAGE}' not found."
        echo "Build it:  xnullclaw image build"
    fi
}

