#!/usr/bin/env bash
# xnullclaw - Multi-agent nullclaw wrapper with hardened Docker isolation
#
# Each agent lives in ~/.xnullclaw/<name>/ with its own config and data.
# Agents run in Docker with: read-only rootfs, all caps dropped,
# no-new-privileges, no exposed ports (Telegram uses outbound polling).
#
# Usage:  xnullclaw <agent> <command> [args...]
#         xnullclaw <global-command>

set -euo pipefail

# ── Configuration ────────────────────────────────────────────────
XNULLCLAW_HOME="${XNULLCLAW_HOME:-$HOME/.xnullclaw}"
DOCKER_IMAGE="${XNULLCLAW_IMAGE:-nullclaw:latest}"
CONTAINER_PREFIX="xnc"
REPO_URL="https://github.com/nullclaw/nullclaw.git"
BUILD_DIR="$XNULLCLAW_HOME/.tmp/nullclaw"

# ── Helpers ──────────────────────────────────────────────────────
die()  { printf '\033[31merror:\033[0m %s\n' "$*" >&2; exit 1; }
info() { printf '\033[34m::\033[0m %s\n' "$*"; }
warn() { printf '\033[33m!!\033[0m %s\n' "$*" >&2; }
ok()   { printf '\033[32mok:\033[0m %s\n' "$*"; }

container_name() { echo "${CONTAINER_PREFIX}-${1}"; }
agent_dir()      { echo "${XNULLCLAW_HOME}/${1}"; }

validate_name() {
    [[ "$1" =~ ^[a-zA-Z][a-zA-Z0-9_-]*$ ]] || \
        die "Invalid agent name '$1'. Use letters, digits, hyphens, underscores. Must start with a letter."
}

agent_exists() { [[ -d "$(agent_dir "$1")" && -f "$(agent_dir "$1")/config.json" ]]; }

is_running() { docker ps -q -f "name=^$(container_name "$1")\$" 2>/dev/null | grep -q .; }

image_exists() { docker image inspect "$DOCKER_IMAGE" &>/dev/null; }

# ── Meta file (key=value store per agent) ────────────────────────
read_meta() {
    local meta; meta="$(agent_dir "$1")/.meta"
    if [[ -f "$meta" ]]; then
        grep "^${2}=" "$meta" 2>/dev/null | head -1 | cut -d= -f2- || echo "${3:-}"
    else
        echo "${3:-}"
    fi
}

write_meta() {
    local meta; meta="$(agent_dir "$1")/.meta"
    if [[ -f "$meta" ]] && grep -q "^${2}=" "$meta" 2>/dev/null; then
        sed -i "s|^${2}=.*|${2}=${3}|" "$meta"
    else
        echo "${2}=${3}" >> "$meta"
    fi
}

next_port() {
    local port=3001
    while true; do
        local used=false
        local metas
        metas=$(compgen -G "$XNULLCLAW_HOME"/*/.meta 2>/dev/null || true)
        for meta in $metas; do
            [[ -f "$meta" ]] && grep -q "^HOST_PORT=${port}$" "$meta" && { used=true; break; }
        done
        $used || { echo "$port"; return; }
        ((port++))
    done
}

ensure_image() {
    if ! image_exists; then
        warn "Docker image '${DOCKER_IMAGE}' not found."
        read -rp "Build it now from GitHub? [Y/n] " ans
        [[ "${ans:-y}" =~ ^[Yy] ]] || die "Cannot proceed without the Docker image."
        cmd_image_build
    fi
}

# ── Image commands ───────────────────────────────────────────────
cmd_image_build() {
    mkdir -p "$XNULLCLAW_HOME/.tmp"
    if [[ -d "$BUILD_DIR/.git" ]]; then
        info "Using existing repo at ${BUILD_DIR}"
    else
        info "Cloning nullclaw..."
        git clone "$REPO_URL" "$BUILD_DIR"
    fi
    info "Building Docker image (compiling Zig — may take a few minutes)..."
    docker build -t "$DOCKER_IMAGE" "$BUILD_DIR"
    ok "Image '${DOCKER_IMAGE}' built."
}

cmd_image_update() {
    mkdir -p "$XNULLCLAW_HOME/.tmp"
    if [[ -d "$BUILD_DIR/.git" ]]; then
        info "Pulling latest changes..."
        git -C "$BUILD_DIR" pull --ff-only
    else
        info "Cloning nullclaw..."
        git clone "$REPO_URL" "$BUILD_DIR"
    fi
    info "Rebuilding Docker image (no cache)..."
    docker build --no-cache -t "$DOCKER_IMAGE" "$BUILD_DIR"
    ok "Image '${DOCKER_IMAGE}' updated."
}

cmd_image_status() {
    if image_exists; then
        docker image inspect "$DOCKER_IMAGE" --format \
            "Image:   {{index .RepoTags 0}}
Created: {{.Created}}
Size:    {{.Size}}
ID:      {{.ID}}"
    else
        echo "Image '${DOCKER_IMAGE}' not found."
        echo "Build it:  xnullclaw image build"
    fi
}

