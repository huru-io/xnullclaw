# ── Docker run helpers ───────────────────────────────────────────
# Common hardening + resource limit args for all docker run invocations.
# Sets _DOCKER_ARGS array. Caller must pass agent dir as $1.
docker_hardened_args() {
    local dir="$1"
    _DOCKER_ARGS=(
        --read-only
        --tmpfs /tmp:size=64M,noexec,nosuid
        --security-opt no-new-privileges:true
        --cap-drop ALL
        --memory 128m
        --memory-swap 128m
        --cpus 0.25
        --pids-limit 64
        --user "$(id -u):$(id -g)"
        -v "${dir}/data:/nullclaw-data"
        -v "${dir}/config.json:/nullclaw-data/.nullclaw/config.json:ro"
    )
}

# ── Agent: setup ─────────────────────────────────────────────────
cmd_setup() {
    local agent="$1"
    _log DEBUG "setup: agent=$agent"
    validate_name "$agent"
    local dir; dir="$(agent_dir "$agent")"

    if agent_exists "$agent"; then
        die "Agent '${agent}' already exists at ${dir}. Use 'clone' to duplicate."
    fi

    mkdir -p "${dir}/data/.nullclaw" "${dir}/data/workspace"
    generate_config > "${dir}/config.json"
    write_meta "$agent" "CREATED" "$(iso_now)"

    local emoji; emoji=$(next_emoji)
    write_meta "$agent" "EMOJI" "$emoji"

    ok "Agent '${agent}' created. ${emoji}"
    cat <<EOF

  Directory: ${dir}/

  ┌─ EDIT BEFORE STARTING ─────────────────────────────────────┐
  │                                                             │
  │  \$ ${EDITOR:-vi} ${dir}/config.json
  │                                                             │
  │  REQUIRED:                                                  │
  │    Set your OpenAI API key:                                 │
  │      models.providers.openai.api_key                        │
  │                                                             │
  │  REQUIRED — Telegram:                                       │
  │    1. Create a bot via @BotFather on Telegram               │
  │    2. Set channels.telegram.accounts.main.bot_token         │
  │    3. Set allow_from to your Telegram user ID               │
  │       (use @userinfobot on Telegram to get your ID)         │
  │                                                             │
  │    Each agent needs its OWN Telegram bot.                   │
  │    Create a separate bot via @BotFather for each agent.     │
  │                                                             │
  │  OPTIONAL — Switch provider:                                │
  │    agents.defaults.model.primary can be:                    │
  │      "openai/gpt-4o"                                        │
  │      "openai/gpt-4o-mini"                                   │
  │      "openrouter/anthropic/claude-sonnet-4"                 │
  │      "anthropic/claude-sonnet-4"                            │
  │                                                             │
  └─────────────────────────────────────────────────────────────┘

  Then:
    xnullclaw ${agent} start      # always-on daemon (Telegram)
    xnullclaw ${agent} cli        # interactive local chat

EOF
}

# ── Agent: start ─────────────────────────────────────────────────
cmd_start() {
    local agent="$1"
    shift
    agent_exists "$agent" || die "Agent '${agent}' not found. Run: xnullclaw ${agent} setup"
    is_running "$agent"   && die "Agent '${agent}' is already running. Use 'restart' to restart."
    ensure_image

    local dir;   dir="$(agent_dir "$agent")"
    local cname; cname=$(container_name "$agent")

    # Parse optional --port and --mux flags
    local expose_port=""
    local mux_mode=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)
                if [[ $# -ge 2 && "$2" =~ ^[0-9]+$ ]]; then
                    expose_port="$2"; shift 2
                else
                    expose_port=$(next_port); shift
                fi
                ;;
            --mux)
                mux_mode=true
                expose_port=$(next_port)
                shift
                ;;
            *) die "Unknown flag: $1" ;;
        esac
    done

    # Clean up any stopped container with the same name
    docker rm "$cname" 2>/dev/null || true

    # Build docker run command
    docker_hardened_args "$dir"
    local run_args=(
        docker run -d
        --name "$cname"
        --restart unless-stopped
        "${_DOCKER_ARGS[@]}"
    )

    if [[ -n "$expose_port" ]]; then
        run_args+=(
            -p "127.0.0.1:${expose_port}:3000"
            -e "NULLCLAW_GATEWAY_HOST=0.0.0.0"
            -e "NULLCLAW_ALLOW_PUBLIC_BIND=true"
        )
        if $mux_mode; then
            run_args+=(
                -e "NULLCLAW_REQUIRE_PAIRING=false"
            )
            write_meta "$agent" "MUX_MODE" "true"
            info "Starting agent '${agent}' in mux mode (port ${expose_port})..."
        else
            info "Starting agent '${agent}' (port ${expose_port})..."
        fi
        write_meta "$agent" "HOST_PORT" "$expose_port"
    else
        info "Starting agent '${agent}' (no port exposed)..."
    fi

    run_args+=("$DOCKER_IMAGE" gateway)

    _log DEBUG "docker run: ${run_args[*]}"
    if ! "${run_args[@]}" >/dev/null; then
        _log ERROR "docker run failed for agent '$agent'"
        die "Failed to start container for agent '${agent}'."
    fi

    sleep 1

    ok "Agent '${agent}' started."
    echo ""
    if [[ -n "$expose_port" ]]; then
        echo "  Gateway: http://127.0.0.1:${expose_port}"
        local code
        code=$(docker logs "$cname" 2>&1 | grep -oE 'pairing code: [0-9]+' | sed 's/pairing code: //' || true)
        [[ -n "$code" ]] && echo "  Pairing: curl -s -X POST http://127.0.0.1:${expose_port}/pair -H 'X-Pairing-Code: ${code}'"
    else
        echo "  No port exposed (Telegram uses outbound polling)."
    fi
    echo "  Logs:    xnullclaw ${agent} logs -f"
    echo "  Stop:    xnullclaw ${agent} stop"
    echo ""
}

# ── Agent: stop ──────────────────────────────────────────────────
cmd_stop() {
    local agent="$1"
    _log DEBUG "stop: agent=$agent"
    if is_running "$agent"; then
        local cname; cname=$(container_name "$agent")
        info "Stopping agent '${agent}'..."
        if ! docker stop "$cname" >/dev/null; then
            _log ERROR "docker stop failed: cname=$cname"
            die "Failed to stop container '${cname}'."
        fi
        docker rm "$cname" >/dev/null 2>&1 || true
        # Clear stale runtime meta
        write_meta "$agent" "HOST_PORT" ""
        write_meta "$agent" "MUX_MODE" ""
        ok "Agent '${agent}' stopped."
    else
        warn "Agent '${agent}' is not running."
    fi
}

# ── Agent: restart ───────────────────────────────────────────────
cmd_restart() {
    local agent="$1"
    _log DEBUG "restart: agent=$agent"
    shift
    if is_running "$agent"; then
        cmd_stop "$agent"
    fi
    cmd_start "$agent" "$@"
}

# ── Agent: status ────────────────────────────────────────────────
cmd_status() {
    local agent="$1"
    agent_exists "$agent" || die "Agent '${agent}' not found."

    local dir; dir="$(agent_dir "$agent")"
    local emoji; emoji=$(read_meta "$agent" "EMOJI" "")

    if [[ -n "$emoji" ]]; then
        echo "Agent:     ${emoji}  ${agent}"
    else
        echo "Agent:     ${agent}"
    fi
    echo "Directory: ${dir}"

    if is_running "$agent"; then
        local cname; cname=$(container_name "$agent")
        local started ports
        started=$(docker inspect "$cname" --format '{{.State.StartedAt}}' 2>/dev/null || echo "?")
        ports=$(docker port "$cname" 2>/dev/null || true)

        echo "Status:    running"
        echo "Started:   ${started}"
        echo "Container: ${cname}"
        if [[ -n "$ports" ]]; then
            echo "Port:      ${ports}"
        else
            echo "Port:      none (outbound-only)"
        fi
    else
        echo "Status:    stopped"
    fi
}

# ── Agent: logs ──────────────────────────────────────────────────
cmd_logs() {
    local agent="$1"; shift
    is_running "$agent" || die "Agent '${agent}' is not running."
    local cname; cname=$(container_name "$agent")
    docker logs "$@" "$cname" 2>&1
}

# ── Agent: cli ───────────────────────────────────────────────────
cmd_cli() {
    local agent="$1"; shift
    _log DEBUG "cli: agent=$agent args=$*"
    agent_exists "$agent" || die "Agent '${agent}' not found. Run: xnullclaw ${agent} setup"
    ensure_image

    local dir; dir="$(agent_dir "$agent")"

    docker_hardened_args "$dir"
    _log DEBUG "docker run (cli): ${_DOCKER_ARGS[*]}"
    docker run --rm -it \
        "${_DOCKER_ARGS[@]}" \
        "$DOCKER_IMAGE" \
        agent "$@"
}

# ── Agent: clone ─────────────────────────────────────────────────
cmd_clone() {
    local agent="$1" source="$2"
    local with_data="${3:-}"
    _log DEBUG "clone: agent=$agent source=$source with_data=$with_data"
    validate_name "$agent"
    validate_name "$source"
    agent_exists "$source" || die "Source agent '${source}' not found."
    agent_exists "$agent"  && die "Agent '${agent}' already exists."

    local src_dir; src_dir="$(agent_dir "$source")"
    local dst_dir; dst_dir="$(agent_dir "$agent")"

    info "Cloning '${source}' -> '${agent}'..."

    mkdir -p "${dst_dir}/data/.nullclaw" "${dst_dir}/data/workspace"
    cp "${src_dir}/config.json" "${dst_dir}/config.json"

    write_meta "$agent" "CREATED" "$(iso_now)"
    write_meta "$agent" "CLONED_FROM" "$source"

    local emoji; emoji=$(next_emoji)
    write_meta "$agent" "EMOJI" "$emoji"

    if [[ "$with_data" == "--with-data" ]]; then
        info "Copying data (memory, workspace, secrets)..."
        cp -a "${src_dir}/data/." "${dst_dir}/data/"
        info "Data copied."
    fi

    ok "Agent '${agent}' cloned from '${source}'. ${emoji}"
    cat <<EOF

  Directory: ${dst_dir}/

  IMPORTANT — Review the config before starting:
    \$ ${EDITOR:-vi} ${dst_dir}/config.json

    - You MUST set a DIFFERENT Telegram bot_token.
      Each agent needs its own bot (@BotFather).
    - API keys are shared from the source config.
      Change them if you want separate billing/accounts.

  Start: xnullclaw ${agent} start

EOF
}

# ── Agent: destroy ───────────────────────────────────────────────
cmd_destroy() {
    local agent="$1"
    _log DEBUG "destroy: agent=$agent"
    local dir; dir="$(agent_dir "$agent")"

    [[ -d "$dir" ]] || die "Agent '${agent}' not found."

    echo "This will PERMANENTLY DELETE agent '${agent}' and ALL its data."
    echo "Directory: ${dir}"
    echo ""
    read -rp "Type the agent name to confirm: " confirm
    [[ "$confirm" == "$agent" ]] || die "Aborted."

    is_running "$agent" && cmd_stop "$agent"

    rm -rf "$dir"
    ok "Agent '${agent}' destroyed."
}

# ── Global: list ─────────────────────────────────────────────────
cmd_list() {
    if [[ ! -d "$XNULLCLAW_HOME" ]]; then
        echo "No agents yet. Create one: xnullclaw <name> setup"
        return
    fi

    local found=false
    printf "\033[1m%-4s %-18s %-10s %-12s %s\033[0m\n" "" "AGENT" "STATUS" "CREATED" "CLONED_FROM"

    for dir in "$XNULLCLAW_HOME"/*/; do
        [[ -d "$dir" ]] || continue
        local name; name=$(basename "$dir")
        [[ "$name" == ".tmp" ]] && continue
        [[ -f "${dir}/config.json" ]] || continue

        found=true
        local created cloned status emoji

        created=$(read_meta "$name" "CREATED" "-")
        cloned=$(read_meta "$name" "CLONED_FROM" "")
        emoji=$(read_meta "$name" "EMOJI" " ")

        if is_running "$name"; then
            status="\033[32mrunning\033[0m"
        else
            status="stopped"
        fi

        printf "%-4s %-18s %-10b %-12s %s\n" \
            "$emoji" "$name" "$status" "${created%%T*}" "$cloned"
    done

    $found || echo "No agents yet. Create one: xnullclaw <name> setup"
}

# ── Agent: send ──────────────────────────────────────────────────
cmd_send() {
    local agent="$1"
    agent_exists "$agent" || die "Agent '${agent}' not found."
    is_running "$agent"   || die "Agent '${agent}' is not running."

    local port; port=$(read_meta "$agent" "HOST_PORT" "")
    [[ -n "$port" ]] || die "Agent '${agent}' has no exposed port. Start with --port or --mux."

    local message
    message=$(cat)
    [[ -n "$message" ]] || die "No message on stdin. Usage: echo 'hello' | xnullclaw ${agent} send"

    local token; token=$(read_meta "$agent" "AUTH_TOKEN" "")
    local curl_args=(
        curl -s -S --max-time 600 --connect-timeout 5
        -X POST "http://127.0.0.1:${port}/webhook"
        -H "Content-Type: application/json"
    )
    [[ -n "$token" ]] && curl_args+=(-H "Authorization: Bearer ${token}")

    local payload
    if ! payload=$(python3 -c "import json,sys; print(json.dumps({'message': sys.stdin.read()}))" <<< "$message"); then
        _log ERROR "python3 json encode failed (is python3 installed?)"
        die "Failed to encode message payload. Ensure python3 is installed."
    fi
    curl_args+=(-d "$payload")

    _log DEBUG "send: agent=$agent port=$port url=http://127.0.0.1:${port}/webhook"
    if ! "${curl_args[@]}"; then
        _log ERROR "curl failed: agent=$agent port=$port"
        return 1
    fi
}

# ── Global: send-all ────────────────────────────────────────────
cmd_send_all() {
    _log DEBUG "send-all"
    local message
    message=$(cat)
    [[ -n "$message" ]] || die "No message on stdin. Usage: echo 'hello' | xnullclaw send-all"

    local agents=()
    for dir in "$XNULLCLAW_HOME"/*/; do
        [[ -d "$dir" ]] || continue
        local name; name=$(basename "$dir")
        [[ "$name" == ".tmp" || "$name" == ".mux" ]] && continue
        [[ -f "${dir}/config.json" ]] || continue
        is_running "$name" && agents+=("$name")
    done

    [[ ${#agents[@]} -gt 0 ]] || die "No running agents found."

    local tmpdir; tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" RETURN

    for agent in "${agents[@]}"; do
        (
            local resp
            resp=$(echo "$message" | cmd_send "$agent" 2>/dev/null || echo '{"error":"failed"}')
            echo "$resp" > "${tmpdir}/${agent}"
        ) &
    done
    wait

    # Build JSON object from results
    python3 -c "
import json, sys, os
results = {}
tmpdir = sys.argv[1]
for name in sorted(os.listdir(tmpdir)):
    with open(os.path.join(tmpdir, name)) as f:
        content = f.read().strip()
    try:
        results[name] = json.loads(content)
    except (json.JSONDecodeError, ValueError):
        results[name] = content
print(json.dumps(results, indent=2))
" "$tmpdir"
}

# ── Global: send-some ───────────────────────────────────────────
cmd_send_some() {
    local agent_list="$1"
    _log DEBUG "send-some: agents=$agent_list"
    [[ -n "$agent_list" ]] || die "Usage: echo 'msg' | xnullclaw send-some alice,bob"

    local message
    message=$(cat)
    [[ -n "$message" ]] || die "No message on stdin."

    IFS=',' read -ra agents <<< "$agent_list"
    [[ ${#agents[@]} -gt 0 ]] || die "No agents specified."

    # Validate all agents first
    for agent in "${agents[@]}"; do
        validate_name "$agent"
        agent_exists "$agent" || die "Agent '${agent}' not found."
        is_running "$agent"   || die "Agent '${agent}' is not running."
    done

    local tmpdir; tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" RETURN

    for agent in "${agents[@]}"; do
        (
            local resp
            resp=$(echo "$message" | cmd_send "$agent" 2>/dev/null || echo '{"error":"failed"}')
            echo "$resp" > "${tmpdir}/${agent}"
        ) &
    done
    wait

    python3 -c "
import json, sys, os
results = {}
tmpdir = sys.argv[1]
for name in sorted(os.listdir(tmpdir)):
    with open(os.path.join(tmpdir, name)) as f:
        content = f.read().strip()
    try:
        results[name] = json.loads(content)
    except (json.JSONDecodeError, ValueError):
        results[name] = content
