FROM golang:1.25-alpine AS builder
ARG VERSION=dev
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags "-s -w -X main.version=${VERSION}" -o /xnc .

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /xnc /usr/local/bin/xnc
USER nonroot
ENTRYPOINT ["xnc"]
CMD ["mux", "start", "--foreground"]
